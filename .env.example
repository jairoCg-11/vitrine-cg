# ==============================
# BANCO DE DADOS
# ==============================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vitrine_cg
POSTGRES_USER=
POSTGRES_PASSWORD=

# ==============================
# MINIO (Storage de fotos)
# ==============================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_PRODUTOS=produtos

# ==============================
# BACKEND
# ==============================
BACKEND_PORT=8000
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==============================
# FRONTEND
# ==============================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000

# URL pública do MinIO (usada pelo frontend para exibir imagens)
# Local: http://localhost:9000
# Produção: https://storage.vitrine-cg.com.br
MINIO_PUBLIC_URL=http://localhost:9000
